# Build output
/build/
/bin/
**/bin/
**/build/
**/dist/
**/coverage/
!gofurry-rag/internal/web/dist/
!gofurry-rag/internal/web/dist/**

# Runtime files
**/logs/
*.log
*.out
*.err
*.pid
*.pid.lock
*.seed

# Frontend dependencies and caches
**/node_modules/
**/.vite/
**/.cache/
**/.turbo/

# Editor and OS files
.DS_Store
Thumbs.db
.idea/
.vs/
*.suo
*.user
*.userossc
*.swp
*.swo

# Environment files
**/.env
**/.env.*
!**/.env.example
